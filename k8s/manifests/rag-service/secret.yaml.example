# Copy to secret.yaml and fill in real values before deploying.
# secret.yaml is gitignored — never commit real credentials.
apiVersion: v1
kind: Secret
metadata:
  name: rag-service-secret
  namespace: jobradar
type: Opaque
stringData:
  postgres-dsn: "postgres://jobradar:REPLACE_ME@postgresql:5432/jobradar?sslmode=disable"
