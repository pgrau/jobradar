# ==============================================================================
# JobRadar — Environment Variables
# Copy this file to .env and fill in the values
# .env is gitignored — never commit real credentials
# ==============================================================================

# ------------------------------------------------------------------------------
# Environment
# Values: local | hetzner
# ------------------------------------------------------------------------------
ENV=local

# ------------------------------------------------------------------------------
# Kubernetes
# ------------------------------------------------------------------------------
NAMESPACE=jobradar
CLUSTER_NAME=jobradar
KUBECONFIG=~/.kube/config

# ------------------------------------------------------------------------------
# Registry
# ------------------------------------------------------------------------------
REGISTRY=ghcr.io/pgrau/jobradar
TAG=latest

# ------------------------------------------------------------------------------
# PostgreSQL 18
# ------------------------------------------------------------------------------
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_DB=jobradar
POSTGRES_USER=jobradar
POSTGRES_PASSWORD=changeme
POSTGRES_SSL_MODE=disable

# ------------------------------------------------------------------------------
# Kafka
# ------------------------------------------------------------------------------
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC_RAW_OFFERS=raw-offers
KAFKA_TOPIC_SCORED_OFFERS=scored-offers
KAFKA_TOPIC_ALERTS=alerts
KAFKA_CONSUMER_GROUP=jobradar

# ------------------------------------------------------------------------------
# Valkey
# ------------------------------------------------------------------------------
VALKEY_ADDR=valkey:6379
VALKEY_PASSWORD=
VALKEY_DB=0

# Rate limiting defaults
VALKEY_RATE_LIMIT_REQUESTS=100
VALKEY_RATE_LIMIT_WINDOW=60s

# LLM response cache TTL
VALKEY_LLM_CACHE_TTL=24h

# ------------------------------------------------------------------------------
# LiteLLM
# ------------------------------------------------------------------------------
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=sk-jobradar

# ------------------------------------------------------------------------------
# LLM Backends
# Local: Ollama
# Production: Google Gemini
# ------------------------------------------------------------------------------

# Ollama (local only)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=mxbai-embed-large

# Google Gemini (production only)
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_EMBED_DIMENSIONS=1024

# ------------------------------------------------------------------------------
# Langfuse
# ------------------------------------------------------------------------------
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ------------------------------------------------------------------------------
# OpenTelemetry (Grafana Alloy)
# ------------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4317
OTEL_SERVICE_NAMESPACE=jobradar
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=${ENV}

# ------------------------------------------------------------------------------
# Auth service (JWT)
# ------------------------------------------------------------------------------
JWT_SECRET=changeme-use-a-long-random-string-in-production
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# ------------------------------------------------------------------------------
# MinIO (CV storage)
# ------------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_CVS=jobradar-cvs
MINIO_USE_SSL=false

# ------------------------------------------------------------------------------
# API Gateway
# ------------------------------------------------------------------------------
API_GATEWAY_PORT=8080
API_GATEWAY_CORS_ORIGINS=http://localhost:5173

# ------------------------------------------------------------------------------
# MCP Server
# ------------------------------------------------------------------------------
MCP_SERVER_PORT=8090

# ------------------------------------------------------------------------------
# A2A Agent
# ------------------------------------------------------------------------------
A2A_AGENT_PORT=8091

# ------------------------------------------------------------------------------
# Frontend (Vite dev server)
# ------------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8080
VITE_MCP_BASE_URL=http://localhost:8090

# ------------------------------------------------------------------------------
# Job Sources
# LinkedIn requires a valid session cookie — see docs/sources/linkedin.md
# ------------------------------------------------------------------------------
LINKEDIN_SESSION_COOKIE=
REMOTEOK_BASE_URL=https://remoteok.com/api
REMOTIVE_BASE_URL=https://remotive.com/api/remote-jobs
WWR_BASE_URL=https://weworkremotely.com/remote-jobs.rss
INFOJOBS_CLIENT_ID=
INFOJOBS_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# Fetcher
# ------------------------------------------------------------------------------
FETCHER_INTERVAL=15m
FETCHER_MAX_OFFERS_PER_SOURCE=100